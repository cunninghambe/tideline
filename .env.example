# uh-oh crash + hang reporting. See docs/06-observability.md.
# DSN format: http://<publicKey>@<host>[:port]
# Get the public key from the uh-oh dashboard → Tideline project → Settings.
# Leave empty in dev to disable observability locally — initObservability() will no-op.
EXPO_PUBLIC_UH_OH_DSN=

# Optional release info attached to every event. Defaults to 0.0.0+0.
EXPO_PUBLIC_APP_VERSION=
EXPO_PUBLIC_APP_BUILD=
